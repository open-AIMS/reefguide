  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@sentry/cli": "^2.53.0",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "jsdom": "^28.1.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
