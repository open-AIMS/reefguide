{
  "name": "@reefguide/db",
  "version": "0.1.0",
  "description": "Database client and schema for ReefGuide",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "db-reset": "prisma db push --force-reset",
    "db-seed": "prisma db seed",
    "lint": "gts lint",
    "type-check": "tsc --noEmit",
    "clean": "gts clean",
    "fix": "gts fix",
    "format:write": "prettier --write \"src/**/*.{ts,js,json,html,scss,md}\" \"!**/node_modules/**\" \"!**/dist/**\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,html,scss,md}\" \"!**/node_modules/**\" \"!**/dist/**\"",
    "db:dump": "dotenv -e .env -- sh -c 'pg_dump \"$DATABASE_URL\" > backup.sql'",
    "db:shell": "dotenv -e .env -- sh -c 'psql \"$DATABASE_URL\"'",
    "db:restore": "./scripts/restore-db.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv-cli": "^10.0.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/language-server": "^31.10.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.6.1",
    "ol": "^10.9.0",
    "pg": "^8.20.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
